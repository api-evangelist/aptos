{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api-evangelist.github.io/aptos/json-schema/MultiKeySignature.json",
  "title": "MultiKeySignature",
  "type": "object",
  "description": "A multi key signature",
  "required": [
    "public_keys",
    "signatures",
    "signatures_required"
  ],
  "properties": {
    "public_keys": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/PublicKey"
      }
    },
    "signatures": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/IndexedSignature"
      }
    },
    "signatures_required": {
      "type": "integer",
      "format": "uint8"
    }
  }
}