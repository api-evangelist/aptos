    {
      "@id": "aptos:U256",
      "@type": "owl:Class",
      "rdfs:label": "U256",
      "rdfs:comment": "A string containing a 256-bit unsigned integer.\n\nWe represent u256 values as a string to ensure compatibility with languages such\nas JavaScript that do not parse u256s in JSON natively.\n"
    },
    {
      "@id": "aptos:U64",
      "@type": "owl:Class",
      "rdfs:label": "U64",
      "rdfs:comment": "A string containing a 64-bit unsigned integer.\n\nWe represent u64 values as a string to ensure compatibility with languages such\nas JavaScript that do not parse u64s in JSON natively.\n"
    },
    {
      "@id": "aptos:UnsupportedJWK",
      "@type": "owl:Class",
      "rdfs:label": "UnsupportedJWK",
      "rdfs:comment": "Move type `0x1::jwks::UnsupportedJWK` in rust.\nSee its doc in Move for more details.",
      "aptos:hasProperty": [
        "id",
        "payload"
      ]
    },
    {
      "@id": "aptos:UserTransaction",
